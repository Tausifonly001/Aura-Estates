# Security
Options -Indexes
ServerSignature Off

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://cdn.tailwindcss.com https://us.i.posthog.com https://maps.googleapis.com https://maps.gstatic.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://cdn.tailwindcss.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://us.i.posthog.com https://api.resend.com https://api.razorpay.com https://maps.googleapis.com https://maps.gstatic.com https://*.googleapis.com https://*.gstatic.com; frame-ancestors 'none';"
</IfModule>

RewriteEngine On

# ====== BLOCK UTILITY SCRIPTS ======
RewriteRule ^(install|update_db|update_blog|update_rbac|migrate_content|add_tenant)\.php$ - [F,L]

# ====== CLEAN URLS: External redirect .php → clean URL (301) ======
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_URI} ^/([^.?]+)\.php(\?.*)?$ [NC]
RewriteCond %{REQUEST_URI} !^/(install|update_db|update_blog|update_rbac|migrate_content|add_tenant|database|api)\.php
RewriteRule ^ /%1 [R=301,L,QSA]

# ====== CLEAN URLS: Internal rewrite clean URL → .php file ======
# Note: RewriteRule pattern in .htaccess strips the directory prefix,
# so these work both at root (Railway) and in subdirectory (local XAMPP).

# Rewrite root-level PHP files (login.php, register.php, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(login|register|forgot-password|reset-password|portal)$ $1.php [L,QSA]

# Rewrite /property-detail/123 → property-detail.php?id=123
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^property-detail/([0-9]+)$ resources/views/pages/property-detail.php?id=$1 [L,QSA]

# Rewrite root-level pages → resources/views/pages/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(about|properties|services|blog|contact|faq|careers|privacy|terms|property-detail|blog-post)$ resources/views/pages/$1.php [L,QSA]

# Rewrite /api/* → api/*.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/([^/]+)$ api/$1.php [L,QSA]

# Rewrite /admin/amenity-bookings → resources/views/admin/amenity_bookings.php
RewriteRule ^admin/amenity-bookings$ resources/views/admin/amenity_bookings.php [L,QSA]

# Rewrite /admin/* → resources/views/admin/*.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^admin/([^/]+)$ resources/views/admin/$1.php [L,QSA]

# Rewrite /user/* → resources/views/user/*.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^user/([^/]+)$ resources/views/user/$1.php [L,QSA]

# Rewrite /admin/blog/* → resources/views/admin/blog/*.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^admin/blog/([^/]+)$ resources/views/admin/blog/$1.php [L]

# ====== EXISTING RULES (keep for backward compatibility) ======
RewriteRule ^about\.php$ resources/views/pages/about.php [L]
RewriteRule ^blog\.php$ resources/views/pages/blog.php [L]
RewriteRule ^blog-post\.php$ resources/views/pages/blog-post.php [L]
RewriteRule ^careers\.php$ resources/views/pages/careers.php [L]
RewriteRule ^contact\.php$ resources/views/pages/contact.php [L]
RewriteRule ^faq\.php$ resources/views/pages/faq.php [L]
RewriteRule ^privacy\.php$ resources/views/pages/privacy.php [L]
RewriteRule ^terms\.php$ resources/views/pages/terms.php [L]
RewriteRule ^properties\.php$ resources/views/pages/properties.php [L]
RewriteRule ^property-detail\.php$ resources/views/pages/property-detail.php [L]
RewriteRule ^services\.php$ resources/views/pages/services.php [L]
RewriteRule ^admin/(.+)$ resources/views/admin/$1 [L]
RewriteRule ^user/(.+)$ resources/views/user/$1 [L]
